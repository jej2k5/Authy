{
  "name": "@authy/core",
  "version": "0.1.0",
  "description": "Multi-provider authentication framework supporting local, Google, M365, and SSO",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit"
  },
  "keywords": ["authentication", "oauth", "oidc", "saml", "google", "m365", "sso"],
  "author": "Authy Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jej2k5/Authy.git"
  },
  "bugs": {
    "url": "https://github.com/jej2k5/Authy/issues"
  },
  "homepage": "https://github.com/jej2k5/Authy#readme",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "jose": "^5.9.6",
    "openid-client": "^5.7.0",
    "samlify": "^2.8.10"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  }
}
